    {"id":"pre_l01_002","type":"choice","module":"语法理解","question":"Choose the polite form: Teacher, ___ hello!","options":[{"text":"您","pinyin":"nín"},{"text":"你","pinyin":"nǐ"},{"text":"你们","pinyin":"nǐmen"},{"text":"大家","pinyin":"dàjiā"}],"answer":"您","weakPoints":"语法：您"},
    {"id":"pre_l01_003","type":"choice","module":"词汇理解","question":"Choose the Chinese word for “everyone”.","options":[{"text":"大家","pinyin":"dàjiā"},{"text":"学生","pinyin":"xuéshēng"},{"text":"同学","pinyin":"tóngxué"},{"text":"好","pinyin":"hǎo"}],"answer":"大家","weakPoints":"词汇：大家"},
    {"id":"pre_l01_004","type":"choice","module":"词汇理解","question":"Choose the Chinese word for “student”.","options":[{"text":"学生","pinyin":"xuéshēng"},{"text":"老师","pinyin":"lǎoshī"},{"text":"你们","pinyin":"nǐmen"},{"text":"再见","pinyin":"zàijiàn"}],"answer":"学生","weakPoints":"词汇：学生"},
    {"id":"pre_l01_005","type":"choice","module":"语法理解","question":"Which word shows a plural group of people?","options":[{"text":"们","pinyin":"men"},{"text":"好","pinyin":"hǎo"},{"text":"您","pinyin":"nín"},{"text":"你好","pinyin":"nǐ hǎo"}],"answer":"们","weakPoints":"语法：们"},
